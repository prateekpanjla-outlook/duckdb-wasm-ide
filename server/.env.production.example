# Production Environment Variables for Cloud Run
# Copy this to .env.production and fill in the values
# In Cloud Run, these should be set as secrets or environment variables

# Server Configuration
NODE_ENV=production
PORT=8080

# Cloud SQL Database Connection
# For Cloud Run, use Unix socket format:
DB_HOST=/cloudsql/YOUR_PROJECT_ID:us-central1:duckdb-ide-db
DB_PORT=5432
DB_NAME=duckdb_ide
DB_USER=postgres
# Use Cloud Secret Manager for password in production
DB_PASSWORD=YOUR_SECURE_PASSWORD

# JWT Configuration
# Generate a strong random string for production
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional: Google Cloud configurations
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_REGION=us-central1
