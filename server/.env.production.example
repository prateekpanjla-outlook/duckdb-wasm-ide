# ============ GOOGLE CLOUD PRODUCTION TEMPLATE ============
# Copy this and fill in your values for Cloud Run deployment
# In Cloud Run, set these as environment variables or use Secret Manager

# Environment
NODE_ENV=production

# ============ DATABASE ============
# Cloud SQL Unix socket connection
# Replace YOUR_PROJECT_ID with your actual Google Cloud project ID
DB_HOST=/cloudsql/YOUR_PROJECT_ID:us-central1:duckdb-ide-db
DB_PORT=5432
DB_NAME=duckdb_ide
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_PASSWORD  # Use Secret Manager in production

# Connection Pool
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ============ JWT ============
# Generate strong secret: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_JWT_SECRET_MIN_32_CHARS  # Use Secret Manager
JWT_EXPIRES_IN=7d

# ============ CORS ============
# Replace with your actual service URL
CORS_ORIGINS=https://YOUR_SERVICE-xxxxx.run.app
CORS_CREDENTIALS=true

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100

# ============ LOGGING ============
LOG_LEVEL=info
STRUCTURED_LOGGING=true

# ============ FEATURES ============
FEATURE_PRACTICE_MODE=true
